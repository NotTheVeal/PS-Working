{
  "manifest_version": 3,
  "name": "PartsSource AI",
  "version": "1.0.0",
  "description": "AI-powered procurement assistant — backorder detection, alternatives, and order automation.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.partssource.com/*",
    "http://localhost:3001/*",
    "http://localhost:5173/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.partssource.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "PartsSource AI"
  }
}
